# Конфигурация прокси (опционально)
PROXY_HTTP=http://user:pass@proxy.example.com:8080
PROXY_HTTPS=http://user:pass@proxy.example.com:8080
PROXY_SOCKS5=socks5://user:pass@proxy.example.com:1080

# Настройки парсера
MAX_RETRIES=3
TIMEOUT=30

# Настройки логирования
LOG_LEVEL=INFO
LOG_FILE=parser.log
